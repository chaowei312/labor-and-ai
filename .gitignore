# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
env/

# Editor / OS
.vscode/
.idea/
.DS_Store
*.swp

# Quarto build artifacts
.quarto/
narrative_site/_site/
narrative_site/.quarto/

# Local screenshot scratch space (never deployed)
narrative_site/agentic_view/

# DSAN 5200 narrative — instructor's classroom guidance: do NOT push data to the
# cloud repo. Raw downloads, processed CSVs and profiling HTML are all
# regeneratable from the fetch + materialize scripts under scripts/narrative/.
data/raw/**/*
!data/raw/**/.gitkeep
data/processed/*.csv
!data/processed/.gitkeep
data/meta/profiles/*
!data/meta/profiles/.gitkeep

# Build artefact for the linked-view chart (data is baked into the HTML output).
narrative_site/figs/linked_view_data.csv

# Forked / cloned upstream repos (keep vendor/README.md + .gitkeep only)
vendor/*
!vendor/README.md
!vendor/.gitkeep

# Claude Design bundle — regeneratable from source via
# `python scripts/build_claude_design_bundle.py`. Don't track its contents.
claude_design_bundle/
claude_design_bundle.zip

# Original Claude Design system zip — already extracted into narrative_site/_design/
Labor & AI Narrative Design System.zip
